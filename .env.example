##############################################
# APPLICATION CONFIGURATION
##############################################

NODE_ENV=production
PORT=8000

##############################################
# DATABASE CONFIGURATION
##############################################

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

##############################################
# AUTHENTICATION & SECURITY
##############################################

JWT_SECRET=your-super-secure-jwt-secret-key-here
JWT_EXPIRES_IN=8h

##############################################
# ADMIN CONFIGURATION
##############################################

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=$2a$10$your.bcrypt.hashed.password.here

##############################################
# FRONTEND CONFIGURATION
##############################################

CLIENT_URL=https://your-frontend-app.netlify.app
FRONTEND_URL=https://your-frontend-app.netlify.app
NETLIFY_URL=https://your-frontend-app.netlify.app

##############################################
# CORS CONFIGURATION
##############################################

CORS_ORIGINS=https://your-frontend-app.netlify.app

##############################################
# AI SERVICE CONFIGURATION
##############################################

AI_SERVICE_URL=https://your-ai-service.onrender.com
AI_SERVICE_TIMEOUT=60000
PYTHON_SCRAPER_URL=https://your-ai-service.onrender.com

##############################################
# LOGGING & DEBUGGING
##############################################

LOG_LEVEL=info
SERVE_FRONTEND=false
FRONTEND_BUILD_PATH=../frontend/out

##############################################
# BROWSER & PLAYWRIGHT
##############################################

PLAYWRIGHT_BROWSERS_PATH=0

##############################################
# SERVER CONFIGURATION
##############################################

TRUST_PROXY=true

##############################################
# SOCKET.IO CONFIGURATION
##############################################

SOCKET_ORIGIN=https://your-frontend-app.netlify.app

##############################################
# COOKIE SETTINGS
##############################################

COOKIE_SECURE=true
COOKIE_SAME_SITE=none
COOKIE_HTTP_ONLY=true