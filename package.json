{
  "name": "lead-finder-backend",
  "version": "1.0.0",
  "description": "Lead Finder Agent - Backend API",
  "main": "server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "seed": "ts-node-dev --transpile-only src/seed.ts",
    "seed:locations": "ts-node-dev --transpile-only --exit src/scripts/seed-locations.ts",
    "prebuild": "npm run clean",
    "build": "tsc --build",
    "postbuild": "echo '[postbuild] TypeScript compilation completed'",
    "postinstall": "npm run build && echo '[postinstall] Installing Playwright Chromium...' && cross-env PLAYWRIGHT_BROWSERS_PATH=./pw-browsers npx playwright install chromium 2>&1 || echo '[postinstall] ⚠️ Chromium install failed — runtime will attempt download if needed'",
    "playwright:install": "cross-env PLAYWRIGHT_BROWSERS_PATH=./pw-browsers npx playwright install chromium",
    "prestart": "node -e \"console.log('Starting Lead Finder Backend...')\"",
    "start": "node server.js",
    "start:prod": "node server.js",
    "start:dev": "cross-env NODE_ENV=development node dist/app.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx,json,md}'",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "health-check": "node health-check.js",
    "verify": "node -e \"require('./dist/app.js'); console.log('App bundle verification passed')\"",
    "deploy-check": "node deploy.js",
    "verify-deployment": "node verify-deployment.js"
  },
  "dependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/csv-write-stream": "^2.0.0",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.20.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.0.0",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "country-state-city": "^3.2.1",
    "cross-env": "^7.0.3",
    "csv-write-stream": "^2.0.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0",
    "morgan": "^1.9.1",
    "node-cron": "^3.0.0",
    "p-limit": "^3.1.0",
    "pino": "^9.2.0",
    "pino-http": "^10.2.0",
    "playwright": "^1.47.0",
    "rimraf": "^3.0.2",
    "socket.io": "^4.8.3",
    "tslib": "^2.7.0",
    "ws": "^8.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.3.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  }
}
